{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PERT Calculator",
  "version": "0.1.0",
  "identifier": "com.user.project-calc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PERT Calculator",
        "width": 402,
        "height": 874,
        "minWidth": 402,
        "maxWidth": 402,
        "minHeight": 874,
        "maxHeight": 874,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
